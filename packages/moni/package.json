{
	"name": "@maddefientist/moni",
	"version": "0.1.0",
	"description": "Moni - Persistent Telegram trading agent",
	"type": "module",
	"bin": {
		"moni": "dist/main.js"
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && chmod +x dist/main.js",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"start": "node dist/main.js"
	},
	"dependencies": {
		"@mariozechner/pi-agent-core": "^0.55.1",
		"@mariozechner/pi-ai": "^0.55.1",
		"@mariozechner/pi-coding-agent": "^0.55.1",
		"@sinclair/typebox": "^0.34.0",
		"chalk": "^5.6.2",
		"croner": "^9.1.0",
		"diff": "^8.0.2",
		"grammy": "^1.35.0"
	},
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/node": "^24.3.0",
		"typescript": "^5.9.2"
	},
	"author": "MadDefientist",
	"license": "MIT",
	"engines": {
		"node": ">=20.0.0"
	}
}
